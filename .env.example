# ==========================================
# إعدادات قاعدة البيانات
# ==========================================

# SQLite (افتراضي - لا يحتاج تثبيت)
DATABASE_URL=sqlite:///mdb_dashboard.db

# ---- MySQL ----
# قم بتثبيت: pip install pymysql
# ثم ضع هذا السطر بدلاً من SQLite:
# DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@localhost:3306/DB_NAME

# ---- PostgreSQL ----
# قم بتثبيت: pip install psycopg2-binary
# ثم ضع هذا السطر بدلاً من SQLite:
# DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/DB_NAME

# ---- SQL Server ----
# قم بتثبيت: pip install pyodbc
# DATABASE_URL=mssql+pyodbc://USERNAME:PASSWORD@SERVER/DB_NAME?driver=ODBC+Driver+17+for+SQL+Server

# ==========================================
# مفاتيح الذكاء الاصطناعي
# ==========================================

# Google Gemini API (مجاني جداً - موصى به)
# احصل على مفتاح من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# OpenAI (ChatGPT)
# احصل على مفتاح من: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# OpenRouter (للإرشاد المكاني - نماذج صوتية ومتعددة)
# احصل على مفتاح من: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# AI/ML API (للإرشاد المكاني - بديل)
# احصل على مفتاح من: https://aimlapi.com/app/keys
AIML_API_KEY=your-aiml-api-key-here

# ==========================================
# إعدادات الأمان
# ==========================================
SECRET_KEY=change-this-to-a-random-long-string-in-production

# وضع الإنتاج (True = HTTPS مطلوب)
PRODUCTION=False
